}

// ─────────────────────────────────────────────────────────────
// GROUP I — REFERRAL SYSTEM
// ─────────────────────────────────────────────────────────────

model Referral {
  id                       Int       @id @default(autoincrement())
  referrerId               Int       @map("referrer_id")
  referredUserId           Int?      @map("referred_user_id")
  referralSourceId         Int?      @map("referral_source_id")
  eventId                  Int?      @map("event_id")
  cityId                   Int?      @map("city_id")
  sharingChannel           String?   @map("sharing_channel") // whatsapp | sms | email
  status                   String // sent | opened | partial_registration | complete_registration
  openedAt                 DateTime? @map("opened_at")
  registeredAt             DateTime? @map("registered_at")
  pointsCredited           Int       @default(0) @map("points_credited")
  pointsCreditedAt         DateTime? @map("points_credited_at")
  pointsExpiresAt          DateTime? @map("points_expires_at")
  redeemedAgainstFreebieId Int?      @map("redeemed_against_freebie_id")
  redeemedAt               DateTime? @map("redeemed_at")
  createdAt                DateTime  @default(now()) @map("created_at")

  referrer       User            @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referredUser   User?           @relation("ReferralReferred", fields: [referredUserId], references: [id])
  referralSource ReferralSource? @relation(fields: [referralSourceId], references: [id])
  event          Event?          @relation(fields: [eventId], references: [id])
  city           City?           @relation(fields: [cityId], references: [id])
  freebie        Freebie?        @relation(fields: [redeemedAgainstFreebieId], references: [id])

  @@map("referrals")
}

model ReferralDailyCap {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  capDate       DateTime @map("cap_date") @db.Date
  referralsSent Int      @default(0) @map("referrals_sent")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, capDate])
  @@map("referral_daily_caps")
}

// ─────────────────────────────────────────────────────────────
// GROUP J — MESSAGING
// ─────────────────────────────────────────────────────────────

model Message {
  id                  Int      @id @default(autoincrement())
  senderId            Int      @map("sender_id")
  receiverId          Int      @map("receiver_id")
  messageType         String   @map("message_type") // direct | enquiry
  content             String
  entityType          String?  @map("entity_type") // sp_profile | event | group | post
  entityId            Int?     @map("entity_id")
  enquiryStatus       String?  @map("enquiry_status") // pending | replied | closed
  conversationId      String?  @map("conversation_id")
  isRead              Boolean  @default(false) @map("is_read")
  isDeletedBySender   Boolean  @default(false) @map("is_deleted_by_sender")
  isDeletedByReceiver Boolean  @default(false) @map("is_deleted_by_receiver")
  createdAt           DateTime @default(now()) @map("created_at")

  sender   User @relation("MessageSender", fields: [senderId], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@map("messages")
}

// ─────────────────────────────────────────────────────────────
// GROUP K — RATINGS
// ─────────────────────────────────────────────────────────────

model ServiceProviderRating {
  id          Int      @id @default(autoincrement())
  profileId   Int      @map("profile_id")
  ratedBy     Int      @map("rated_by")
  rating      Int
  review      String?
  areaContext String?  @map("area_context") // apartment | lane | area | city
  createdAt   DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id])
  rater   User    @relation(fields: [ratedBy], references: [id])

  @@map("service_provider_ratings")
}

// ─────────────────────────────────────────────────────────────
// GROUP L — SEARCH
// ─────────────────────────────────────────────────────────────

model SearchLog {
  id               Int      @id @default(autoincrement())
  userId           Int?     @map("user_id")
  query            String
  filters          Json?
  resultsCount     Int?     @map("results_count")
  resultEntityType String?  @map("result_entity_type") // sp_profile | event | group | post
  resultEntityId   Int?     @map("result_entity_id")
  searchedAt       DateTime @default(now()) @map("searched_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("search_logs")
}

// ─────────────────────────────────────────────────────────────
// GROUP M — ADMIN OPERATIONS
// ─────────────────────────────────────────────────────────────

model ProfileVerification {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  status          String // pending | approved | rejected
  reviewedBy      Int?      @map("reviewed_by")
  rejectionReason String?   @map("rejection_reason")
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user     User   @relation(fields: [userId], references: [id])
  reviewer Admin? @relation(fields: [reviewedBy], references: [id])

  @@map("profile_verifications")
}

model WhitelistedBlacklistedUser {
  id     Int      @id @default(autoincrement())
  userId Int      @map("user_id")
  status String // whitelisted | blacklisted
  reason String?
  setBy  Int?     @map("set_by")
  setAt  DateTime @default(now()) @map("set_at")

  user       User   @relation(fields: [userId], references: [id])
  setByAdmin Admin? @relation(fields: [setBy], references: [id])

  @@map("whitelisted_blacklisted_users")
}

model AdminEmail {
  id             Int      @id @default(autoincrement())
  adminId        Int      @map("admin_id")
  toUserId       Int?     @map("to_user_id")
  replyToEmailId Int?     @map("reply_to_email_id")
  subject        String
  body           String
  emailTag       String?  @map("email_tag") // verification | announcement | warning | reminder
  direction      String   @default("outbound") // outbound | inbound
  sentAt         DateTime @default(now()) @map("sent_at")

  admin   Admin        @relation(fields: [adminId], references: [id])
  toUser  User?        @relation(fields: [toUserId], references: [id])
  replyTo AdminEmail?  @relation("EmailThread", fields: [replyToEmailId], references: [id])
  replies AdminEmail[] @relation("EmailThread")

  @@map("admin_emails")
}

model PermissionMaster {
  id        Int     @id @default(autoincrement())
  userType  String  @map("user_type") // resident | service_provider
  action    String // event_create | event_edit | ...
  isAllowed Boolean @default(true) @map("is_allowed")

  @@map("permissions_master")
}

/// Complete audit trail for all admin actions.
model AdminAuditLog {
  id          Int      @id @default(autoincrement())
  adminId     Int      @map("admin_id")
  action      String
  entityType  String?  @map("entity_type")
  entityId    Int?     @map("entity_id")
  details     Json?
  performedAt DateTime @default(now()) @map("performed_at")

  admin Admin @relation(fields: [adminId], references: [id])

  @@map("admin_audit_logs")
}

// ─────────────────────────────────────────────────────────────
// GROUP N — ORDERS
// ─────────────────────────────────────────────────────────────

model Order {
  id                  Int       @id @default(autoincrement())
  buyerId             Int       @map("buyer_id")
  spProfileId         Int       @map("sp_profile_id")
  status              String // placed | confirmed | in_progress | delivered | completed | cancelled | refund_requested
  deliveryType        String?   @map("delivery_type") // home_delivery | pickup
  deliveryAddressId   Int?      @map("delivery_address_id")
  scheduledSlotId     Int?      @map("scheduled_slot_id")
  subtotal            Decimal   @db.Decimal(10, 2)
  deliveryCharge      Decimal   @default(0) @map("delivery_charge") @db.Decimal(10, 2)
  discountApplied     Decimal   @default(0) @map("discount_applied") @db.Decimal(10, 2)
  totalAmount         Decimal   @map("total_amount") @db.Decimal(10, 2)
  couponId            Int?      @map("coupon_id")
  specialInstructions String?   @map("special_instructions")
  placedAt            DateTime  @default(now()) @map("placed_at")
  confirmedAt         DateTime? @map("confirmed_at")
  deliveredAt         DateTime? @map("delivered_at")
  completedAt         DateTime? @map("completed_at")
  cancelledAt         DateTime? @map("cancelled_at")
  cancellationReason  String?   @map("cancellation_reason")

  buyer           User             @relation(fields: [buyerId], references: [id])
  spProfile       Profile          @relation(fields: [spProfileId], references: [id])
  deliveryAddress Address?         @relation(fields: [deliveryAddressId], references: [id])
  scheduledSlot   SpScheduleSlot?  @relation("OrderScheduledSlot", fields: [scheduledSlotId], references: [id])
  coupon          CouponCode?      @relation(fields: [couponId], references: [id])
  slotBookings    SpScheduleSlot[] @relation("SlotOrder")
  items           OrderItem[]
  payments        OrderPayment[]

  @@map("orders")
}

model OrderItem {
  id                 Int     @id @default(autoincrement())
  orderId            Int     @map("order_id")
  productId          Int     @map("product_id")
  quantity           Decimal @default(1) @db.Decimal(10, 3)
  unitPrice          Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice         Decimal @map("total_price") @db.Decimal(10, 2)
  customizationNotes String? @map("customization_notes")

  order   Order     @relation(fields: [orderId], references: [id])
  product SpProduct @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderPayment {
  id             Int       @id @default(autoincrement())
  orderId        Int       @map("order_id")
  amount         Decimal   @db.Decimal(10, 2)
  paymentType    String    @map("payment_type") // advance | partial | final | refund
  paymentMethod  String?   @map("payment_method") // cash | upi | card | net_banking | bank_transfer
  paymentStatus  String    @map("payment_status") // pending | paid | failed | refunded
  transactionRef String?   @map("transaction_ref")
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("order_payments")
}

// ─────────────────────────────────────────────────────────────
// GROUP O — REFUND REQUESTS
// ─────────────────────────────────────────────────────────────

model RefundRequest {
  id                Int       @id @default(autoincrement())
  requestedBy       Int       @map("requested_by")
  entityType        String    @map("entity_type") // event | group | order
  entityId          Int       @map("entity_id")
  amountRequested   Decimal   @map("amount_requested") @db.Decimal(10, 2)
  reason            String?
  status            String // pending | approved | rejected | processed
  reviewedBy        Int?      @map("reviewed_by")
  reviewedAt        DateTime? @map("reviewed_at")
  refundProcessedAt DateTime? @map("refund_processed_at")
  refundAmount      Decimal?  @map("refund_amount") @db.Decimal(10, 2)
  transactionRef    String?   @map("transaction_ref")
  createdAt         DateTime  @default(now()) @map("created_at")

  requester User   @relation(fields: [requestedBy], references: [id])
  reviewer  Admin? @relation(fields: [reviewedBy], references: [id])

  @@map("refund_requests")
}

// ─────────────────────────────────────────────────────────────
// GROUP P — NOTIFICATIONS
// ─────────────────────────────────────────────────────────────

model Notification {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  title            String
  body             String?
  notificationType String   @map("notification_type")
  entityType       String?  @map("entity_type")
  entityId         Int?     @map("entity_id")
  isRead           Boolean  @default(false) @map("is_read")
  isPushed         Boolean  @default(false) @map("is_pushed")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// GROUP Q — STATS (denormalised)
// ─────────────────────────────────────────────────────────────

model UserStats {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique @map("user_id")
  servicesAvailed       Int      @default(0) @map("services_availed")
  messagesSent          Int      @default(0) @map("messages_sent")
  repliesPending        Int      @default(0) @map("replies_pending")
  postsMade             Int      @default(0) @map("posts_made")
  eventsHosted          Int      @default(0) @map("events_hosted")
  groupsPartOf          Int      @default(0) @map("groups_part_of")
  referralPointsBalance Int      @default(0) @map("referral_points_balance")
  leadsReceived         Int      @default(0) @map("leads_received")
  leadsRejected         Int      @default(0) @map("leads_rejected")
  ordersReceived        Int      @default(0) @map("orders_received")
  paymentReceivedTotal  Decimal  @default(0) @map("payment_received_total") @db.Decimal(10, 2)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_stats")
}
