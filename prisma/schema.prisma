// Link Local — Prisma schema
// Translated from DBML v6. PostgreSQL.
// Convention: PascalCase models / camelCase fields in Prisma, mapped to
// snake_case tables/columns in the database via @@map / @map.
// Enum-like columns are kept as String to mirror the DBML's flexible varchars;
// allowed values are documented in comments next to each field.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// GROUP A — ADMIN MASTER TABLES
// ─────────────────────────────────────────────────────────────

model City {
  id        Int      @id @default(autoincrement())
  name      String
  state     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  areas             Area[]
  referralPoints    CityReferralPoint[]
  allowedDocTypes   CityAllowedDocType[]
  addressVerifyDocs AddressVerificationDoc[]
  cityMemberships   UserCityMembership[]
  referrals         Referral[]
  addressFields     CityAddressField[]
  addressMasters    AddressMaster[]

  @@map("cities")
}

/// Per-city address-capture form configuration (PRD: "the format of the address
/// capture form will be different for different cities and set up at ADMIN level").
model CityAddressField {
  id         Int     @id @default(autoincrement())
  cityId     Int     @map("city_id")
  fieldKey   String  @map("field_key") // flat_wing | building | lane1 | lane2 | area | suburb | pincode | landmark | sector | district
  label      String
  isRequired Boolean @default(false) @map("is_required")
  isVisible  Boolean @default(true) @map("is_visible")
  sortOrder  Int     @default(0) @map("sort_order")

  city City @relation(fields: [cityId], references: [id])

  @@unique([cityId, fieldKey])
  @@map("city_address_fields")
}

model Area {
  id       Int     @id @default(autoincrement())
  cityId   Int     @map("city_id")
  pincode  String?
  suburb   String?
  areaName String  @map("area_name")
  isActive Boolean @default(true) @map("is_active")

  city      City      @relation(fields: [cityId], references: [id])
  addresses Address[]

  @@map("areas")
}

model ServiceCategory {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  subcategories ServiceSubcategory[]

  @@map("service_categories")
}

model ServiceSubcategory {
  id         Int     @id @default(autoincrement())
  categoryId Int     @map("category_id")
  name       String
  isActive   Boolean @default(true) @map("is_active")

  category     ServiceCategory           @relation(fields: [categoryId], references: [id])
  fields       ServiceSubcategoryField[]
  serviceTypes ProfileServiceType[]

  @@map("service_subcategories")
}

/// Admin-configured dynamic profile fields per service subcategory.
model ServiceSubcategoryField {
  id            Int     @id @default(autoincrement())
  subcategoryId Int     @map("subcategory_id")
  fieldName     String  @map("field_name")
  fieldType     String  @map("field_type") // text | number | date | dropdown | boolean
  fieldOptions  String? @map("field_options") // JSON array of options if field_type = dropdown
  isRequired    Boolean @default(false) @map("is_required")
  sortOrder     Int     @default(0) @map("sort_order")
  isActive      Boolean @default(true) @map("is_active")

  subcategory  ServiceSubcategory     @relation(fields: [subcategoryId], references: [id])
  customValues SpProfileCustomField[]

  @@map("service_subcategory_fields")
}

/// SP values for dynamic subcategory fields.
model SpProfileCustomField {
  id         Int    @id @default(autoincrement())
  profileId  Int    @map("profile_id")
  fieldId    Int    @map("field_id")
  fieldValue String @map("field_value")

  profile Profile                 @relation(fields: [profileId], references: [id])
  field   ServiceSubcategoryField @relation(fields: [fieldId], references: [id])

  @@map("sp_profile_custom_fields")
}

model EducationMaster {
  id              Int     @id @default(autoincrement())
  degree          String?
  schoolName      String? @map("school_name")
  schoolCity      String? @map("school_city")
  collegeName     String? @map("college_name")
  collegeCity     String? @map("college_city")
  university      String?
  postGradCollege String? @map("post_grad_college")
  postGradCity    String? @map("post_grad_city")

  profileEducations ProfileEducation[]

  @@map("education_master")
}

model ProfessionMaster {
  id       Int    @id @default(autoincrement())
  category String // Salaried | Business | Freelancer | Consultant | Student | Retired | Advisor | On-Contract

  profileProfessions ProfileProfession[]

  @@map("profession_master")
}

/// Admin-controlled hobbies list.
model HobbiesMaster {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true) @map("is_active")

  profileHobbies ProfileHobby[]

  @@map("hobbies_master")
}

model CouponCode {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  discountType  String    @map("discount_type") // amount_off | percent_off
  discountValue Decimal   @map("discount_value") @db.Decimal(10, 2)
  validityFrom  DateTime? @map("validity_from") @db.Date
  validityTo    DateTime? @map("validity_to") @db.Date
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  isActive      Boolean   @default(true) @map("is_active")
  createdBy     Int?      @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  creator               Admin?                 @relation(fields: [createdBy], references: [id])
  usageLogs             CouponUsageLog[]
  profilesMarketing     Profile[]
  events                Event[]
  eventPayments         EventPayment[]
  interestGroups        InterestGroup[]
  interestGroupPayments InterestGroupPayment[]
  orders                Order[]

  @@map("coupon_codes")
}

/// Tracks WHO used each coupon and WHEN.
model CouponUsageLog {
  id         Int      @id @default(autoincrement())
  couponId   Int      @map("coupon_id")
  userId     Int      @map("user_id")
  entityType String   @map("entity_type") // event | group | order
  entityId   Int      @map("entity_id")
  usedAt     DateTime @default(now()) @map("used_at")

  coupon CouponCode @relation(fields: [couponId], references: [id])
  user   User       @relation(fields: [userId], references: [id])

  @@map("coupon_usage_log")
}

model ProfileTag {
  id      Int    @id @default(autoincrement())
  tagName String @unique @map("tag_name")

  tagsMap ProfileTagMap[]

  @@map("profile_tags")
}

model ReferralSource {
  id     Int     @id @default(autoincrement())
  source String // user_id | event_id | social_media | friends_family | print_media | neighbourhood_poster | other
  label  String?

  users     User[]
  referrals Referral[]

  @@map("referral_sources")
}

model Freebie {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  pointsRequired Int      @map("points_required")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  referrals Referral[]

  @@map("freebies")
}

model CityReferralPoint {
  id                 Int       @id @default(autoincrement())
  cityId             Int       @map("city_id")
  pointsPerReferral  Int       @map("points_per_referral")
  bonusPointsNewCity Int       @default(0) @map("bonus_points_new_city")
  isActive           Boolean   @default(true) @map("is_active")
  effectiveFrom      DateTime? @map("effective_from") @db.Date
  createdBy          Int?      @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")

  city    City   @relation(fields: [cityId], references: [id])
  creator Admin? @relation(fields: [createdBy], references: [id])

  @@map("city_referral_points")
}

model CityAllowedDocType {
  id       Int     @id @default(autoincrement())
  cityId   Int     @map("city_id")
  docType  String  @map("doc_type") // rental_agreement | utility_bill | govt_id | bank_statement | employment_letter | other
  isActive Boolean @default(true) @map("is_active")

  city City @relation(fields: [cityId], references: [id])

  @@map("city_allowed_doc_types")
}

// ─────────────────────────────────────────────────────────────
// GROUP B — AUTH & USERS
// ─────────────────────────────────────────────────────────────

model User {
  id               Int      @id @default(autoincrement())
  mobile           String?  @unique @db.VarChar(15)
  email            String?  @unique
  passwordHash     String?  @map("password_hash")
  authType         String   @map("auth_type") // otp | password
  userType         String   @map("user_type") // resident | service_provider | business_listing
  referralCode     String?  @unique @map("referral_code")
  referredBy       Int?     @map("referred_by")
  referralSourceId Int?     @map("referral_source_id")
  isVerified       Boolean  @default(false) @map("is_verified")
  isActive         Boolean  @default(true) @map("is_active")
  isBlocked        Boolean  @default(false) @map("is_blocked")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  referrer       User?           @relation("UserReferrals", fields: [referredBy], references: [id])
  referredUsers  User[]          @relation("UserReferrals")
  referralSource ReferralSource? @relation(fields: [referralSourceId], references: [id])

  couponUsageLogs       CouponUsageLog[]
  blocksInitiated       BlockedUser[]                    @relation("UserBlocker")
  blocksReceived        BlockedUser[]                    @relation("UserBlocked")
  otpTokens             OtpToken[]
  devices               UserDevice[]
  visibilityCircles     VisibilityCircle[]
  circleMemberships     VisibilityCircleMember[]
  cityMemberships       UserCityMembership[]
  profile               Profile?
  familyEntries         ProfileFamily[]
  scheduleSlotsBooked   SpScheduleSlot[]                 @relation("SlotBookedBy")
  posts                 Post[]
  postLikes             PostLike[]
  postComments          PostComment[]
  postCommentReactions  PostCommentReaction[]
  postShares            PostShare[]
  postReposts           PostRepost[]
  feedRemovalRequests   FeedRemovalRequest[]
  entityShares          EntityShare[]
  abuseReportsMade      AbuseReport[]                    @relation("AbuseReporter")
  abuseReportsAgainst   AbuseReport[]                    @relation("AbuseReportedUser")
  eventsCreated         Event[]                          @relation("EventCreator")
  eventsCloned          Event[]                          @relation("EventCloner")
  eventAttendees        EventAttendee[]
  eventRatings          EventRating[]
  eventPayments         EventPayment[]
  eventInvites          EventInvitedUser[]
  eventDeletionRequests EventDeletionRequest[]
  groupsCreated         InterestGroup[]
  groupAdmins           InterestGroupAdmin[]
  groupMembers          InterestGroupMember[]
  groupPayments         InterestGroupPayment[]
  groupRatings          InterestGroupRating[]
  groupInvites          InterestGroupInvitedUser[]
  groupTransfersFrom    InterestGroupOwnershipTransfer[] @relation("TransferFrom")
  groupTransfersTo      InterestGroupOwnershipTransfer[] @relation("TransferTo")
  groupTransfersInit    InterestGroupOwnershipTransfer[] @relation("TransferInitiator")
  referralsMade         Referral[]                       @relation("ReferralReferrer")
  referralsReceived     Referral[]                       @relation("ReferralReferred")
  referralDailyCaps     ReferralDailyCap[]
  messagesSent          Message[]                        @relation("MessageSender")
  messagesReceived      Message[]                        @relation("MessageReceiver")
  ratingsGiven          ServiceProviderRating[]
  searchLogs            SearchLog[]
  profileVerifications  ProfileVerification[]
  whitelistEntries      WhitelistedBlacklistedUser[]
  adminEmailsReceived   AdminEmail[]
  orders                Order[]
  refundRequests        RefundRequest[]
  notifications         Notification[]
  stats                 UserStats?

  @@map("users")
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String? // super_admin | ops_admin
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  couponsCreated         CouponCode[]
  cityReferralPoints     CityReferralPoint[]
  addressDocsReviewed    AddressVerificationDoc[]
  profileTagsAssigned    ProfileTagMap[]
  eventDeletionsReviewed EventDeletionRequest[]
  profileVerifications   ProfileVerification[]
  whitelistSet           WhitelistedBlacklistedUser[]
  emails                 AdminEmail[]
  auditLogs              AdminAuditLog[]
  abuseReportsReviewed   AbuseReport[]
  refundRequestsReviewed RefundRequest[]

  @@map("admins")
}

model BlockedUser {
  id         Int      @id @default(autoincrement())
  blockerId  Int      @map("blocker_id")
  blockedId  Int      @map("blocked_id")
  reason     String?
  blockScope String   @default("full") @map("block_scope") // full | messaging | contact_details | posts | events | groups
  blockedAt  DateTime @default(now()) @map("blocked_at")

  blocker User @relation("UserBlocker", fields: [blockerId], references: [id])
  blocked User @relation("UserBlocked", fields: [blockedId], references: [id])

  @@map("blocked_users")
}

/// Stores OTPs for mobile/email verification.
model OtpToken {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  mobile    String?  @db.VarChar(15)
  email     String?
  otpCode   String   @map("otp_code")
  purpose   String // login | registration | password_reset
  isUsed    Boolean  @default(false) @map("is_used")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("otp_tokens")
}

/// Push notification tokens and active session tracking.
model UserDevice {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  deviceType   String    @map("device_type") // ios | android | web
  deviceToken  String?   @map("device_token")
  deviceName   String?   @map("device_name")
  lastActiveAt DateTime? @map("last_active_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_devices")
}

// ─────────────────────────────────────────────────────────────
// GROUP C — ADDRESS SYSTEM & VISIBILITY CIRCLES
// ─────────────────────────────────────────────────────────────

model Address {
  id          Int      @id @default(autoincrement())
  areaId      Int      @map("area_id")
  flatWing    String?  @map("flat_wing")
  apartment   String?
  lane1       String?
  lane2       String?
  fullAddress String?  @map("full_address")
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  area              Area                     @relation(fields: [areaId], references: [id])
  verificationDocs  AddressVerificationDoc[]
  profiles          Profile[]
  pickupPreferences SpDeliveryPreference[]
  orders            Order[]

  @@map("addresses")
}

model AddressVerificationDoc {
  id         Int       @id @default(autoincrement())
  addressId  Int       @map("address_id")
  cityId     Int       @map("city_id")
  docType    String    @map("doc_type")
  docUrl     String    @map("doc_url")
  status     String? // pending | approved | rejected
  reviewedBy Int?      @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  address  Address @relation(fields: [addressId], references: [id])
  city     City    @relation(fields: [cityId], references: [id])
  reviewer Admin?  @relation(fields: [reviewedBy], references: [id])

  @@map("address_verification_docs")
}

/// Address Master — the curated, deduplicated set of localities that powers the app's
/// autocomplete and 2 km-radius autofill. This is the source of truth for address
/// SUGGESTIONS only: it holds lane1 / lane2 / area / suburb / city / pincode + a
/// representative lat/lng, and intentionally NEVER stores per-user building, flat, or
/// plot numbers (those stay private on `Address`). New localities a user introduces are
/// queued as `pending` and only become suggestions to others once an admin approves them.
model AddressMaster {
  id          Int       @id @default(autoincrement())
  cityId      Int       @map("city_id")
  complex     String? // building / complex name (from the curated directory; used for search autofill — never a user's flat/plot)
  lane1       String?
  lane2       String?
  area        String? // areaName / locality
  suburb      String?
  pincode     String?
  latitude    Decimal?  @db.Decimal(10, 7)
  longitude   Decimal?  @db.Decimal(10, 7)
  status      String    @default("pending") // pending | approved | rejected
  source      String    @default("user") // user | admin | import
  submittedBy Int?      @map("submitted_by")
  reviewedBy  Int?      @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  city City @relation(fields: [cityId], references: [id])

  @@index([cityId, status])
  @@map("address_master")
}

model VisibilityCircle {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  name      String
  scope     String? // apartment | lane | area | city
  createdAt DateTime @default(now()) @map("created_at")

  user           User?                    @relation(fields: [userId], references: [id])
  members        VisibilityCircleMember[]
  profilesUsing  Profile[]
  contactDetails ProfileContactDetail[]
  posts          Post[]
  events         Event[]
  interestGroups InterestGroup[]

  @@map("visibility_circles")
}

model VisibilityCircleMember {
  id       Int      @id @default(autoincrement())
  circleId Int      @map("circle_id")
  userId   Int      @map("user_id")
  addedAt  DateTime @default(now()) @map("added_at")

  circle VisibilityCircle @relation(fields: [circleId], references: [id])
  user   User             @relation(fields: [userId], references: [id])

  @@map("visibility_circle_members")
}

/// Supports border residents belonging to multiple cities.
model UserCityMembership {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  cityId    Int      @map("city_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  joinedAt  DateTime @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id])
  city City @relation(fields: [cityId], references: [id])

  @@unique([userId, cityId])
  @@map("user_city_memberships")
}

// ─────────────────────────────────────────────────────────────
// GROUP D — UNIFIED PROFILES
// ─────────────────────────────────────────────────────────────

model Profile {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @unique @map("user_id")
  name                    String
  photoUrl                String?   @map("photo_url")
  dateOfBirth             DateTime? @map("date_of_birth") @db.Date
  gender                  String? // male | female | do_not_disclose
  aboutMe                 String?   @map("about_me")
  addressId               Int?      @map("address_id")
  ownershipType           String?   @map("ownership_type") // owned | rented
  residingSince           DateTime? @map("residing_since") @db.Date
  canOfferHelpWith        String?   @map("can_offer_help_with")
  socialMediaShareEnabled Boolean   @default(false) @map("social_media_share_enabled")
  visibilityCircleId      Int?      @map("visibility_circle_id")
  yearsOfExperience       Int?      @map("years_of_experience")
  marketingCouponId       Int?      @map("marketing_coupon_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user             User                       @relation(fields: [userId], references: [id])
  address          Address?                   @relation(fields: [addressId], references: [id])
  visibilityCircle VisibilityCircle?          @relation(fields: [visibilityCircleId], references: [id])
  marketingCoupon  CouponCode?                @relation(fields: [marketingCouponId], references: [id])
  customFields     SpProfileCustomField[]
  completion       ProfileCompletionTracking?
  privacy          ProfilePrivacySetting?
  educations       ProfileEducation[]
  hobbies          ProfileHobby[]
  professions      ProfileProfession[]
  contactDetails   ProfileContactDetail[]
  tagsMap          ProfileTagMap[]
  pets             ProfilePet[]
  family           ProfileFamily[]
  serviceTypes     ProfileServiceType[]
  media            ProfileMedia[]
  products         SpProduct[]
  delivery         SpDeliveryPreference?
  unavailability   SpUnavailability[]
  paymentMethods   SpPaymentMethod[]
  paymentTerms     SpPaymentTerm?
  scheduleSlots    SpScheduleSlot[]
  ratings          ServiceProviderRating[]
  orders           Order[]

  @@map("profiles")
}

/// Admin dashboard: new-member profile completion tracking.
model ProfileCompletionTracking {
  id                 Int       @id @default(autoincrement())
  profileId          Int       @unique @map("profile_id")
  hasPhoto           Boolean   @default(false) @map("has_photo")
  hasAddress         Boolean   @default(false) @map("has_address")
  hasAddressVerified Boolean   @default(false) @map("has_address_verified")
  hasEducation       Boolean   @default(false) @map("has_education")
  hasProfession      Boolean   @default(false) @map("has_profession")
  hasContactDetails  Boolean   @default(false) @map("has_contact_details")
  hasServiceTypes    Boolean   @default(false) @map("has_service_types")
  hasProducts        Boolean   @default(false) @map("has_products")
  hasDeliveryPrefs   Boolean   @default(false) @map("has_delivery_prefs")
  hasPaymentMethods  Boolean   @default(false) @map("has_payment_methods")
  completionPercent  Int       @default(0) @map("completion_percent")
  lastComputedAt     DateTime? @map("last_computed_at")

  profile Profile @relation(fields: [profileId], references: [id])

  @@map("profile_completion_tracking")
}

/// Per-field visibility settings. Each *_circle_id references visibility_circles.id;
/// kept as scalar columns (enforced in app logic) to avoid 11 bidirectional relations.
model ProfilePrivacySetting {
  id                           Int  @id @default(autoincrement())
  profileId                    Int  @unique @map("profile_id")
  profileVisibilityCircleId    Int? @map("profile_visibility_circle_id")
  searchVisibilityCircleId     Int? @map("search_visibility_circle_id")
  nameVisibilityCircleId       Int? @map("name_visibility_circle_id")
  ageVisibilityCircleId        Int? @map("age_visibility_circle_id")
  genderVisibilityCircleId     Int? @map("gender_visibility_circle_id")
  addressVisibilityCircleId    Int? @map("address_visibility_circle_id")
  educationVisibilityCircleId  Int? @map("education_visibility_circle_id")
  professionVisibilityCircleId Int? @map("profession_visibility_circle_id")
  contactVisibilityCircleId    Int? @map("contact_visibility_circle_id")
  messagingAccessCircleId      Int? @map("messaging_access_circle_id")
  ratingsVisibilityCircleId    Int? @map("ratings_visibility_circle_id")

  profile Profile @relation(fields: [profileId], references: [id])

  @@map("profile_privacy_settings")
}

model ProfileEducation {
  id                Int  @id @default(autoincrement())
  profileId         Int  @map("profile_id")
  educationMasterId Int? @map("education_master_id")

  profile         Profile          @relation(fields: [profileId], references: [id])
  educationMaster EducationMaster? @relation(fields: [educationMasterId], references: [id])

  @@map("profile_education")
}

model ProfileHobby {
  id            Int     @id @default(autoincrement())
  profileId     Int     @map("profile_id")
  hobbyMasterId Int?    @map("hobby_master_id")
  customHobby   String? @map("custom_hobby")

  profile     Profile        @relation(fields: [profileId], references: [id])
  hobbyMaster HobbiesMaster? @relation(fields: [hobbyMasterId], references: [id])

  @@map("profile_hobbies")
}

model ProfileProfession {
  id                 Int     @id @default(autoincrement())
  profileId          Int     @map("profile_id")
  professionMasterId Int?    @map("profession_master_id")
  companyOrDetail    String? @map("company_or_detail")

  profile          Profile           @relation(fields: [profileId], references: [id])
  professionMaster ProfessionMaster? @relation(fields: [professionMasterId], references: [id])

  @@map("profile_professions")
}

model ProfileContactDetail {
  id                 Int    @id @default(autoincrement())
  profileId          Int    @map("profile_id")
  contactType        String @map("contact_type") // phone | whatsapp | email | other
  value              String
  visibilityCircleId Int?   @map("visibility_circle_id")

  profile          Profile           @relation(fields: [profileId], references: [id])
  visibilityCircle VisibilityCircle? @relation(fields: [visibilityCircleId], references: [id])

  @@map("profile_contact_details")
}

model ProfileTagMap {
  id         Int      @id @default(autoincrement())
  profileId  Int      @map("profile_id")
  tagId      Int      @map("tag_id")
  assignedBy Int?     @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")

  profile  Profile    @relation(fields: [profileId], references: [id])
  tag      ProfileTag @relation(fields: [tagId], references: [id])
  assigner Admin?     @relation(fields: [assignedBy], references: [id])

  @@map("profile_tags_map")
}

model ProfilePet {
  id        Int     @id @default(autoincrement())
  profileId Int     @map("profile_id")
  name      String?
  type      String?
  breed     String?
