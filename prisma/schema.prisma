// ─────────────────────────────────────────────────────────────
// GROUP G — EVENTS
// ─────────────────────────────────────────────────────────────

model Event {
  id                  Int       @id @default(autoincrement())
  creatorId           Int       @map("creator_id")
  parentEventId       Int?      @map("parent_event_id")
  clonedBy            Int?      @map("cloned_by")
  title               String
  description         String?
  photoUrl            String?   @map("photo_url")
  date                DateTime  @db.Date
  startTime           DateTime? @map("start_time") @db.Time
  durationMinutes     Int?      @map("duration_minutes")
  mode                String // online | offline
  location            String?
  onlineLink          String?   @map("online_link")
  visibilityCircleId  Int?      @map("visibility_circle_id")
  isPrivate           Boolean   @default(false) @map("is_private")
  isPaid              Boolean   @default(false) @map("is_paid")
  price               Decimal?  @db.Decimal(10, 2)
  maxAttendees        Int?      @map("max_attendees")
  couponId            Int?      @map("coupon_id")
  eligibilityMinAge   Int?      @map("eligibility_min_age")
  eligibilityGender   String?   @map("eligibility_gender") // all | male | female
  adminApprovalNeeded Boolean   @default(false) @map("admin_approval_needed")
  allowCloning        Boolean   @default(false) @map("allow_cloning")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  creator          User                   @relation("EventCreator", fields: [creatorId], references: [id])
  cloner           User?                  @relation("EventCloner", fields: [clonedBy], references: [id])
  parentEvent      Event?                 @relation("EventClones", fields: [parentEventId], references: [id])
  clones           Event[]                @relation("EventClones")
  visibilityCircle VisibilityCircle?      @relation(fields: [visibilityCircleId], references: [id])
  coupon           CouponCode?            @relation(fields: [couponId], references: [id])
  rawMaterials     EventRawMaterial[]
  attendees        EventAttendee[]
  ratings          EventRating[]          @relation("EventRatingEvent")
  ratingsAsParent  EventRating[]          @relation("EventRatingParent")
  payments         EventPayment[]
  invitedUsers     EventInvitedUser[]
  deletionRequests EventDeletionRequest[]
  referrals        Referral[]

  @@map("events")
}

model EventRawMaterial {
  id       Int    @id @default(autoincrement())
  eventId  Int    @map("event_id")
  material String

  event Event @relation(fields: [eventId], references: [id])

  @@map("event_raw_materials")
}

model EventAttendee {
  id            Int      @id @default(autoincrement())
  eventId       Int      @map("event_id")
  userId        Int      @map("user_id")
  status        String // joined | withdrawn | pending_approval
  paymentStatus String?  @map("payment_status") // paid | unpaid | refunded
  joinedAt      DateTime @default(now()) @map("joined_at")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("event_attendees")
}

model EventRating {
  id            Int      @id @default(autoincrement())
  eventId       Int      @map("event_id")
  parentEventId Int?     @map("parent_event_id")
  userId        Int      @map("user_id")
  rating        Int?
  review        String?
  createdAt     DateTime @default(now()) @map("created_at")

  event       Event  @relation("EventRatingEvent", fields: [eventId], references: [id])
  parentEvent Event? @relation("EventRatingParent", fields: [parentEventId], references: [id])
  user        User   @relation(fields: [userId], references: [id])

  @@map("event_ratings")
}

model EventPayment {
  id              Int       @id @default(autoincrement())
  eventId         Int       @map("event_id")
  userId          Int       @map("user_id")
  amount          Decimal   @db.Decimal(10, 2)
  couponId        Int?      @map("coupon_id")
  discountApplied Decimal   @default(0) @map("discount_applied") @db.Decimal(10, 2)
  paymentStatus   String    @map("payment_status") // pending | paid | refunded
  transactionRef  String?   @map("transaction_ref")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  event  Event       @relation(fields: [eventId], references: [id])
  user   User        @relation(fields: [userId], references: [id])
  coupon CouponCode? @relation(fields: [couponId], references: [id])

  @@map("event_payments")
}

model EventInvitedUser {
  id            Int      @id @default(autoincrement())
  eventId       Int      @map("event_id")
  invitedUserId Int      @map("invited_user_id")
  invitedAt     DateTime @default(now()) @map("invited_at")
  status        String? // pending | accepted | declined

  event       Event @relation(fields: [eventId], references: [id])
  invitedUser User  @relation(fields: [invitedUserId], references: [id])

  @@map("event_invited_users")
}

model EventDeletionRequest {
  id          Int       @id @default(autoincrement())
  eventId     Int       @map("event_id")
  requestedBy Int       @map("requested_by")
  reason      String?
  status      String? // pending | approved | rejected
  reviewedBy  Int?      @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  event     Event  @relation(fields: [eventId], references: [id])
  requester User   @relation(fields: [requestedBy], references: [id])
  reviewer  Admin? @relation(fields: [reviewedBy], references: [id])

  @@map("event_deletion_requests")
}

// ─────────────────────────────────────────────────────────────
// GROUP H — INTEREST GROUPS
// ─────────────────────────────────────────────────────────────

model InterestGroup {
  id                    Int       @id @default(autoincrement())
  creatorId             Int       @map("creator_id")
  title                 String
  description           String?
  photoUrl              String?   @map("photo_url")
  durationDays          Int?      @map("duration_days")
  validityFrom          DateTime? @map("validity_from") @db.Date
  validityTo            DateTime? @map("validity_to") @db.Date
  visibilityCircleId    Int?      @map("visibility_circle_id")
  isPrivate             Boolean   @default(false) @map("is_private")
  isPaid                Boolean   @default(false) @map("is_paid")
  price                 Decimal?  @db.Decimal(10, 2)
  couponId              Int?      @map("coupon_id")
  maxMembers            Int?      @map("max_members")
  eligibilityMinAge     Int?      @map("eligibility_min_age")
  eligibilityGender     String?   @map("eligibility_gender") // all | male | female
  adminApprovalNeeded   Boolean   @default(false) @map("admin_approval_needed")
  multipleAdminsAllowed Boolean   @default(false) @map("multiple_admins_allowed")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  creator            User                             @relation(fields: [creatorId], references: [id])
  visibilityCircle   VisibilityCircle?                @relation(fields: [visibilityCircleId], references: [id])
  coupon             CouponCode?                      @relation(fields: [couponId], references: [id])
  admins             InterestGroupAdmin[]
  members            InterestGroupMember[]
  payments           InterestGroupPayment[]
  posts              InterestGroupPost[]
  ratings            InterestGroupRating[]
  invitedUsers       InterestGroupInvitedUser[]
  ownershipTransfers InterestGroupOwnershipTransfer[]

  @@map("interest_groups")
}

model InterestGroupAdmin {
  id        Int      @id @default(autoincrement())
  groupId   Int      @map("group_id")
  userId    Int      @map("user_id")
  isCreator Boolean  @default(false) @map("is_creator")
  addedAt   DateTime @default(now()) @map("added_at")

  group InterestGroup @relation(fields: [groupId], references: [id])
  user  User          @relation(fields: [userId], references: [id])

  @@map("interest_group_admins")
}

model InterestGroupMember {
  id            Int      @id @default(autoincrement())
  groupId       Int      @map("group_id")
  userId        Int      @map("user_id")
  status        String // joined | exited | pending_approval
  paymentStatus String?  @map("payment_status") // paid | unpaid | refunded
  joinedAt      DateTime @default(now()) @map("joined_at")

  group InterestGroup @relation(fields: [groupId], references: [id])
  user  User          @relation(fields: [userId], references: [id])

  @@map("interest_group_members")
}

model InterestGroupPayment {
  id              Int       @id @default(autoincrement())
  groupId         Int       @map("group_id")
  userId          Int       @map("user_id")
  amount          Decimal   @db.Decimal(10, 2)
  couponId        Int?      @map("coupon_id")
  discountApplied Decimal   @default(0) @map("discount_applied") @db.Decimal(10, 2)
  paymentStatus   String    @map("payment_status") // pending | paid | refunded
  transactionRef  String?   @map("transaction_ref")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  group  InterestGroup @relation(fields: [groupId], references: [id])
  user   User          @relation(fields: [userId], references: [id])
  coupon CouponCode?   @relation(fields: [couponId], references: [id])

  @@map("interest_group_payments")
}

model InterestGroupPost {
  id      Int @id @default(autoincrement())
  groupId Int @map("group_id")
  postId  Int @map("post_id")

  group InterestGroup @relation(fields: [groupId], references: [id])
  post  Post          @relation(fields: [postId], references: [id])

  @@map("interest_group_posts")
}

model InterestGroupRating {
  id        Int      @id @default(autoincrement())
  groupId   Int      @map("group_id")
  userId    Int      @map("user_id")
  rating    Int?
  review    String?
  createdAt DateTime @default(now()) @map("created_at")

  group InterestGroup @relation(fields: [groupId], references: [id])
  user  User          @relation(fields: [userId], references: [id])

  @@map("interest_group_ratings")
}

model InterestGroupInvitedUser {
  id            Int      @id @default(autoincrement())
  groupId       Int      @map("group_id")
  invitedUserId Int      @map("invited_user_id")
  invitedAt     DateTime @default(now()) @map("invited_at")
  status        String? // pending | accepted | declined

  group       InterestGroup @relation(fields: [groupId], references: [id])
  invitedUser User          @relation(fields: [invitedUserId], references: [id])

  @@map("interest_group_invited_users")
}

model InterestGroupOwnershipTransfer {
  id              Int      @id @default(autoincrement())
  groupId         Int      @map("group_id")
  transferredFrom Int      @map("transferred_from")
  transferredTo   Int      @map("transferred_to")
  transferReason  String?  @map("transfer_reason") // voluntary | creator_exit_request | admin_action
  initiatedBy     Int?     @map("initiated_by")
  transferredAt   DateTime @default(now()) @map("transferred_at")

  group     InterestGroup @relation(fields: [groupId], references: [id])
